{
  "manifest_version": 3,
  "name": "Ahgora Tools - Suite de Ferramentas",
  "version": "2.0.0",
  "description": "Suite de ferramentas: Auto Puxa Chat Zendesk, Clonar Perfis PontoWeb e Trocar Base Ahgora | Copyright © Delean Mafra | CC BY-NC 4.0",
  "author": "Delean Mafra",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "*://*.zendesk.com/*",
    "*://*.ahgora.com.br/*",
    "<all_urls>"
  ],
  "content_scripts": [
    {
      "matches": ["*://*.zendesk.com/*"],
      "js": ["license-config.js", "content-zendesk.js", "content-agentes.js", "content-ahtools-sidebar.js", "content-ahgora-search.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["*://*.ahgora.com.br/*", "<all_urls>"],
      "js": ["license-config.js", "content-perfil.js", "content-ahtools-sidebar.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/imagem_principal.png",
    "32": "icons/imagem_principal.png",
    "48": "icons/imagem_principal.png",
    "128": "icons/imagem_principal.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/imagem_principal.png",
      "48": "icons/imagem_principal.png",
      "128": "icons/imagem_principal.png"
    }
  }
}
